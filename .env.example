# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Polymarket Wallet ────────────────────────────────────────────────────────
# Export from polymarket.com → Settings → Export Private Key
POLYMARKET_PRIVATE_KEY=your_exported_private_key_here

# Your Polymarket proxy wallet address (shown on polymarket.com/portfolio deposit screen)
POLYMARKET_FUNDER_ADDRESS=your_polymarket_proxy_address_here

# Signature type: 1 = POLY_PROXY (email/Magic login — most common if you use polymarket.com)
# Use 0 = EOA if you connected a raw MetaMask wallet directly
POLYMARKET_SIGNATURE_TYPE=1

# ─── Risk Parameters ─────────────────────────────────────────────────────────
MAX_STAKE_USD=20
MIN_STAKE_USD=1
DAILY_LOSS_LIMIT_USD=50
MAX_OPEN_TRADES=8
MIN_EDGE_PCT=5
MIN_CONFIDENCE_PCT=62

# ─── Agent Settings ──────────────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=45

# ─── Three-Model Architecture ─────────────────────────────────────────────────
# Scout (Haiku): fast first-pass filter, ~$0.001/market, runs on every market
SCOUT_MODEL=claude-haiku-4-5-20251001
# Judge (Sonnet): deep analysis, ~$0.015/market, only runs on scout-approved markets
JUDGE_MODEL=claude-sonnet-4-6
# Validator (Gemini): live web search + independent validation before execution
# gemini-2.5-flash — best balance of speed + intelligence
# gemini-2.5-pro   — deepest reasoning, use if credits allow
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=your_gemini_api_key_here

# ─── News API (Optional) ─────────────────────────────────────────────────────
# GNews free tier: 100 req/day — leave blank to use without key (rate limited)
GNEWS_API_KEY=your-gnews-api-key-here

# ─── TinyFish (Optional — Layer 1 news enrichment) ───────────────────────────
# TinyFish provides high-quality web search/scrape results for each category.
# Layer 1: TinyFish (richest context). Layer 2: free APIs (always available).
# If key is missing or TF errors 3x in a row, falls through to Layer 2 silently.
TINYFISH_API_KEY=your-tinyfish-api-key-here

# ─── Dashboard ───────────────────────────────────────────────────────────────
DASHBOARD_PORT=3000
WS_PORT=3001

# ─── Supabase ────────────────────────────────────────────────────────────────
# Free project: https://supabase.com → New project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# How long to cache market data before re-fetching (minutes)
MARKET_CACHE_TTL_MINUTES=10

# ─── Polymarket API ──────────────────────────────────────────────────────────
# Polymarket Gamma API (market data) — no key required
GAMMA_API_URL=https://gamma-api.polymarket.com
# Polymarket CLOB API (order placement)
CLOB_API_URL=https://clob.polymarket.com
