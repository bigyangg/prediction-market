{
  "name": "polybot",
  "version": "1.0.0",
  "description": "Autonomous Polymarket Trading Engine",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "pm2": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop polybot && pm2 delete polybot",
    "pm2:logs": "pm2 logs polybot",
    "pm2:monit": "pm2 monit",
    "tunnel": "node start.js",
    "tunnel:stop": "node start.js --stop",
    "tunnel:local": "node start.js --no-tunnel"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@google/genai": "^1.46.0",
    "@polymarket/clob-client": "latest",
    "@supabase/supabase-js": "^2.99.3",
    "axios": "^1.6.0",
    "dotenv": "^16.4.0",
    "ethers": "^5.8.0",
    "express": "^4.18.0",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "ws": "^8.16.0"
  },
  "engines": {
    "node": ">=20.0.0 <22.0.0"
  }
}
